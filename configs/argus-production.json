{
  "server": {
    "listeners": [
      {
        "address": ":15432",
        "protocol": "postgresql",
        "tls": {
          "enabled": true,
          "cert_file": "/etc/argus/tls/server.crt",
          "key_file": "/etc/argus/tls/server.key",
          "client_auth": true,
          "client_ca_file": "/etc/argus/tls/client-ca.crt"
        }
      },
      {
        "address": ":13306",
        "protocol": "mysql"
      }
    ]
  },
  "targets": [
    {
      "name": "production-pg",
      "protocol": "postgresql",
      "host": "$ENV{DB_PG_HOST}",
      "port": 5432,
      "tls": {
        "enabled": true,
        "ca_file": "/etc/argus/tls/db-ca.crt",
        "verify": true
      }
    },
    {
      "name": "production-mysql",
      "protocol": "mysql",
      "host": "$ENV{DB_MYSQL_HOST}",
      "port": 3306
    }
  ],
  "routing": {
    "default_target": "production-pg",
    "rules": [
      {"database": "mysql_*", "target": "production-mysql"}
    ]
  },
  "policy": {
    "files": [
      "/etc/argus/policies/base.json",
      "/etc/argus/policies/production.json"
    ],
    "reload_interval": "5s"
  },
  "pool": {
    "max_connections_per_target": 200,
    "min_idle_connections": 10,
    "connection_max_lifetime": "1h",
    "connection_timeout": "10s",
    "health_check_interval": "15s"
  },
  "session": {
    "idle_timeout": "30m",
    "max_duration": "8h",
    "max_per_user": 10
  },
  "rewrite": {
    "max_limit": 10000
  },
  "slow_query": {
    "threshold": "5s"
  },
  "audit": {
    "level": "standard",
    "outputs": [
      {
        "type": "file",
        "path": "/var/log/argus/audit.jsonl",
        "rotation": {
          "max_size_mb": 100,
          "max_files": 10
        }
      }
    ],
    "buffer_size": 50000,
    "sql_max_length": 4096,
    "pii_auto_detect": true,
    "record_file": "/var/log/argus/queries.jsonl",
    "webhook_url": "$ENV{SIEM_WEBHOOK_URL}"
  },
  "admin": {
    "enabled": true,
    "address": ":9090",
    "auth_token": "$ENV{ARGUS_ADMIN_TOKEN}"
  },
  "metrics": {
    "enabled": true,
    "address": ":9091"
  },
  "gateway": {
    "enabled": true,
    "api_keys": [
      {
        "key": "$ENV{GATEWAY_API_KEY}",
        "username": "web_dashboard",
        "roles": ["analyst"],
        "database": "production",
        "rate_limit": 10,
        "enabled": true
      }
    ],
    "max_result_rows": 10000,
    "approval_timeout": "10m",
    "webhook_url": "$ENV{GATEWAY_APPROVAL_WEBHOOK}",
    "require_approval": {
      "risk_level_gte": "high",
      "commands": ["DDL", "DCL"]
    }
  }
}
